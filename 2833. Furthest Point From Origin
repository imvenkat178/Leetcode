class Solution {
    public int furthestDistanceFromOrigin(String moves) {
        int cl = 0;
        int cr = 0;
        int res = 0;
        for(char ch : moves.toCharArray())
        {
            if(ch == 'L')
            {
                cl ++;
            }if(ch == 'R')
            {
                cr++;
            }
        }
        if(cl == cr)
        {
            res = moves.length() - cl -cr;
        }
        if(cl > cr)
        {
            res = moves.length() - (2*cr);
        }
        else{
            res = moves.length() - (2*cl);
        }
        return res;

             
    }
}
