class Solution {
    public boolean containsCycle(char[][] grid) {
        int n = grid.length;
        int m = grid[0].length;
        int[][] visited  = new int[n][m];
        for(int i=0;i < n;i++)
        {
            for(int j = 0 ; j < m ;j++)
            {
                if(visited[i][j] == 0) {  
            if(dfs(i, j, -1, -1, visited, grid)) {  
                return true;
            }
        }
            }
        }
        return false;
    }

    private boolean dfs(int i,int j , int pi , int pj ,int[][] visited , char[][] grid)
    {
        if(visited[i][j] == 1)
        {
            return true;
        }
        visited[i][j] = 1;


        if(i+1 < grid.length && grid[i][j] == grid[i+1][j] && !(i+1 == pi && j == pj))
    {
        if(dfs(i+1 , j , i, j, visited, grid)) return true;
    }
    if(i-1 >= 0 && grid[i][j] == grid[i-1][j] && !(i-1 == pi && j == pj))
    {
        if(dfs(i-1 , j , i, j, visited, grid)) return true;
    }
    if(j+1 < grid[0].length && grid[i][j] == grid[i][j+1] && !(i == pi && j+1 == pj))
    {
        if(dfs(i , j+1 , i, j, visited, grid)) return true;
    }
    if(j-1 >=0 && grid[i][j] == grid[i][j-1] && !(i == pi && j-1 == pj))
    {
        if(dfs(i , j-1 , i, j, visited, grid)) return true;
    }
    
    return false; 
    }
}
