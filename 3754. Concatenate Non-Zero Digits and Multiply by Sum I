class Solution {
    public long sumAndMultiply(int n) {
        StringBuilder sb = new StringBuilder();
        int sum = 0;
    
        String numStr = String.valueOf(n);
        for (char c : numStr.toCharArray()) {
            if (c != '0') {
                sb.append(c);
                sum += (c - '0');
            }
        }

        if (sb.length() == 0) return 0;

        long x = Long.parseLong(sb.toString());
        
        return x * sum;
    }
}
