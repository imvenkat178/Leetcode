class Solution {
    public boolean canBeEqual(String s1, String s2) {
        StringBuilder st = new StringBuilder(s2);
        for(int i=0;i<2;i++)
        {
            if(s1.charAt(i) != s2.charAt(i))
            {
                st.setCharAt(i,s2.charAt(i+2));
                st.setCharAt(i+2,s2.charAt(i));
            }
        }
        String s = st.toString();
        return s1.equals(s);
    }
}
