class Solution {
    public int binaryGap(int n) {
        int max = 0;
        int curr = -1;
        int prev = -1;
        int i = 0;

        while (n != 0) {
            int bit = n & 1;
            if (bit == 1) {
                if (curr != -1) {
                    prev = curr;
                    curr = i;
                    max = Math.max(max, curr - prev);
                } else {
                    curr = i;
                }
            }
            n >>= 1;
            i++;
        }
        return max;
    }
}
