class Solution {
    public int maxDistance(int[] nums1, int[] nums2) {
    int i = 0, maxDist = 0;
    for (int j = 0; j < nums2.length; j++) {
        while (i < nums1.length && nums1[i] > nums2[j]) {
            i++;
        }
        if (i < nums1.length && i <= j) {
            maxDist = Math.max(maxDist, j - i);
        }
    }
    return maxDist;
    }
}
