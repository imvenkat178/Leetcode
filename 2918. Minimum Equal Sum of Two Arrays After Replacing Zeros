class Solution {
    public long minSum(int[] nums1, int[] nums2) {
        long sum1 = 0;
        boolean hasZeroInNums1 = false;
      
        for (int num : nums1) {
            hasZeroInNums1 |= (num == 0);
            sum1 += Math.max(num, 1);
        }
        long sum2 = 0;
        for (int num : nums2) {
            sum2 += Math.max(num, 1);
        }
        if (sum1 > sum2) {
            return minSum(nums2, nums1);
        }
        if (sum1 == sum2) {
            return sum1;
        }
        return hasZeroInNums1 ? sum2 : -1;
    }
}
