class Solution {
    public String processStr(String s) {
        StringBuilder st = new StringBuilder("");
        for(char c : s.toCharArray())
        {
            if(c == '*')
            {
                st.setLength(Math.max(0,st.length()-1));
            }else if(c == '#')
            {
                st.append(st);
            }else if(c== '%')
            {
                st.reverse();
            }else{
                st.append(c);
            }
        }
        return st.toString();
    }
}
